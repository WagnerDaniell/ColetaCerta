    <bpmn:textAnnotation id="TextAnnotation_16n4sce">
      <bpmn:text>-Foto do lixo
-Localização automática
-Tipo/quantidade (opcional)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_11yw0qm">
      <bpmn:text>Coleta concluída</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0o0whru">
      <bpmn:text>- Quantidade de lixo
- Regiões com maior demanda
- Frequência de registros
- Horários críticos
- Ruas prioritárias</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1b37mp9">
      <bpmn:text>- Mapas de calor
- Rotas recomendadas
- Bairros críticos
- Volume por região
- Histórico operacional</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1i3inee">
      <bpmn:text>- Novas rotas
- Aumento de frequência
- Prioridades de coleta
- Redistribuição de equipes</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1ifc8nt">
      <bpmn:text>- Redução de lixo acumulado
- Melhor tempo de coleta
- Redução de custos
- Maior eficiência operacional</bpmn:text>
    </bpmn:textAnnotation>
